# --- BOT AUTHENTICATION ---
# The API token from your Telegram bot (via BotFather)
TELEGRAM_TOKEN=your_token
# Your numeric Telegram user ID (security access control)
TELEGRAM_USER_ID=your_id

# --- PORTAL CREDENTIALS ---
# Login email or username for the Attendance Portal
LOGIN_USER=user@example.com
# Login password for the portal
LOGIN_PASS=your_password
# Base login URL of the portal
LOGIN_URL=https://example.com/login
# Direct action URL for attendance interaction
ACTION_URL=https://example.com/action

# --- WORK SHIFT TIMES (IN MINUTES) ---
# Standard workday duration Mon-Thu (e.g., 8h 35min = 515)
WORK_MINUTES_REGULAR=515
# Mandatory lunch break duration for Mon-Thu (e.g., 1h = 60)
WORK_MINUTES_LUNCH=60
# Intensive workday duration for Fridays (e.g., 6h = 360)
WORK_MINUTES_FRIDAY=360
# Intensive workday duration for Summer Period (e.g., 7h = 420)
WORK_MINUTES_SUMMER=420

# --- RANDOM JITTER ---
# Max minutes to randomly add to the end of the shift (human simulation)
WORK_RANDOM_DELAY_MAX=10

# --- SUMMER PERIOD CONFIGURATION (MM-DD) ---
# Start date for the summer intensive schedule (inclusive)
SUMMER_PERIOD_START="07-16"
# End date for the summer intensive schedule (inclusive)
SUMMER_PERIOD_END="08-31"
